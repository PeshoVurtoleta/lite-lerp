{
  "name": "@zakkster/lite-lerp",
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "version": "1.1.0",
  "description": "Zero-dependency game math primitives — lerp, clamp, damp, smoothstep, easings, shortest-path angle interpolation, moveToward, wrap, repeat, pingpong, snap, deadzone. Tree-shakeable pure functions, <1KB minified.",
  "type": "module",
  "main": "./Lerp.js",
  "module": "./Lerp.js",
  "types": "./Lerp.d.ts",
  "exports": {
    ".": {
      "types": "./Lerp.d.ts",
      "node": "./Lerp.js",
      "import": "./Lerp.js",
      "default": "./Lerp.js"
    }
  },
  "files": [
    "Lerp.js",
    "Lerp.d.ts",
    "llms.txt",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "node scripts/size.mjs",
    "prepublishOnly": "npm test && npm run size"
  },
  "license": "MIT",
  "homepage": "https://github.com/PeshoVurtoleta/lite-lerp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeshoVurtoleta/lite-lerp.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-lerp/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/PeshoVurtoleta"
  },
  "sideEffects": false,
  "devDependencies": {
    "esbuild": "^0.21.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "lerp",
    "clamp",
    "smoothstep",
    "easing",
    "math",
    "game",
    "interpolation",
    "damp",
    "remap",
    "moveToward",
    "wrap",
    "pingpong",
    "repeat",
    "snap",
    "deadzone",
    "smootherstep",
    "unity",
    "mathf"
  ]
}
